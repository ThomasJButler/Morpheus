# ==============================================================================
# MORPHEUS RAG CHATBOT - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ==============================================================================
# API KEYS (Required)
# ==============================================================================

# Anthropic API Key - Get from: https://console.anthropic.com/
# Used for: Claude LLM responses (all RAG modes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key - Get from: https://platform.openai.com/api-keys
# Used for: Text embeddings (converting text to vectors)
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone API Key - Get from: https://app.pinecone.io/
# Used for: Vector database storage and retrieval
PINECONE_API_KEY=your_pinecone_api_key_here

# ==============================================================================
# PINECONE CONFIGURATION (Required)
# ==============================================================================

# Pinecone Index Name - Create in Pinecone console
# Used for: Dense vector storage (semantic search)
# Dimensions: Must match EMBEDDING_MODEL output (512 for text-embedding-3-small)
PINECONE_INDEX_NAME=morpheus

# Pinecone Sparse Index Name (Optional for hybrid search)
# Used for: Sparse vector storage (keyword search/BM25)
# Only needed if USE_HYBRID_SEARCH=true
PINECONE_SPARSE_INDEX_NAME=morpheus-sparse

# Pinecone Environment - Your Pinecone region
# Common values: us-east-1, us-west-1, eu-west-1, asia-southeast-1
PINECONE_ENVIRONMENT=us-east-1

# ==============================================================================
# MODEL CONFIGURATION
# ==============================================================================

# Anthropic Model - Which Claude model to use
# Options: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# Recommendation: claude-3-haiku-20240307 for speed, claude-3-sonnet for balance
ANTHROPIC_MODEL=claude-3-haiku-20240307

# OpenAI Embedding Model - Which embedding model to use
# Options: text-embedding-3-small (512 dims), text-embedding-3-large (1536 dims)
# Recommendation: text-embedding-3-small for cost-effectiveness
EMBEDDING_MODEL=text-embedding-3-small

# Reranker Model - Cross-encoder model for reranking results
# Used in hybrid/cascading retrieval mode
# Default: bge-reranker-v2-m3 (Pinecone's recommended reranker)
RERANKER_MODEL=bge-reranker-v2-m3

# ==============================================================================
# RAG CONFIGURATION
# ==============================================================================

# Max Chunk Size - Maximum characters per text chunk
# Larger = more context, fewer chunks; Smaller = more granular retrieval
# Recommendation: 1000 for balanced performance
MAX_CHUNK_SIZE=1000

# Chunk Overlap - Characters of overlap between consecutive chunks
# Ensures context continuity across chunk boundaries
# Recommendation: 200 (20% of chunk size)
CHUNK_OVERLAP=200

# Top K Results - Number of chunks to retrieve from vector DB
# Higher = more context but slower; Lower = faster but less comprehensive
# Recommendation: 10 for most use cases
TOP_K_RESULTS=10

# Rerank Top K - Number of results to keep after reranking
# Only used in hybrid/cascading mode
# Recommendation: 5 to filter out noise
RERANK_TOP_K=5

# Min Relevance Score - Minimum similarity score to include result
# Range: 0.0 (all results) to 1.0 (only perfect matches)
# Recommendation: 0.7 for high-quality results
MIN_RELEVANCE_SCORE=0.7

# ==============================================================================
# HYBRID SEARCH CONFIGURATION
# ==============================================================================

# Dense Weight - Weight for semantic/vector search results
# Range: 0.0 to 1.0 (must sum to 1.0 with SPARSE_WEIGHT)
# Recommendation: 0.7 (favor semantic understanding)
DENSE_WEIGHT=0.7

# Sparse Weight - Weight for keyword/BM25 search results
# Range: 0.0 to 1.0 (must sum to 1.0 with DENSE_WEIGHT)
# Recommendation: 0.3 (supplement with keyword matching)
SPARSE_WEIGHT=0.3

# Use Reranker - Enable cross-encoder reranking in hybrid mode
# true = Apply reranker (better results, slower)
# false = Skip reranker (faster, may have noise)
USE_RERANKER=true

# Use Hybrid Search - Enable hybrid (dense + sparse) search
# true = Use both semantic and keyword search
# false = Use only semantic search
USE_HYBRID_SEARCH=true

# ==============================================================================
# DOCUMENT PROCESSING
# ==============================================================================

# Supported File Types - Comma-separated list of allowed extensions
# Default supports common document formats
SUPPORTED_FILE_TYPES=pdf,txt,md,docx

# Max File Size (MB) - Maximum upload size in megabytes
# Recommendation: 50MB for most documents, increase for large PDFs
MAX_FILE_SIZE_MB=50

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# API Host - Which interface to bind to
# 0.0.0.0 = All interfaces (required for Docker)
# localhost = Local only
API_HOST=0.0.0.0

# API Port - Which port to run the server on
# Default: 8000 (FastAPI convention)
API_PORT=8000

# CORS Origins - Comma-separated list of allowed origins
# Required for frontend to communicate with backend
# Add your frontend URL (Vercel, Netlify, etc.)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limit - API rate limiting
# Format: requests/period (e.g., "10/minute", "100/hour")
# Helps prevent abuse and manage costs
RATE_LIMIT=10/minute

# ==============================================================================
# LOGGING
# ==============================================================================

# Log Level - Logging verbosity
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommendation: INFO for production, DEBUG for development
LOG_LEVEL=INFO

# Log File - Path to log file (relative to backend/ directory)
# Directory will be created if it doesn't exist
LOG_FILE=logs/app.log

# ==============================================================================
# DEVELOPMENT OPTIONS (Optional)
# ==============================================================================

# Debug Mode - Enable FastAPI debug mode
# true = Show detailed errors, auto-reload
# false = Production mode
DEBUG=false

# Auto Reload - Restart server on code changes
# true = Development mode (auto-reload)
# false = Production mode (manual restart)
RELOAD=false

# ==============================================================================
# SETUP CHECKLIST
# ==============================================================================
# [ ] Copy this file to .env
# [ ] Get Anthropic API key from console.anthropic.com
# [ ] Get OpenAI API key from platform.openai.com
# [ ] Get Pinecone API key from app.pinecone.io
# [ ] Create Pinecone index with correct dimensions (512 for text-embedding-3-small)
# [ ] (Optional) Create sparse index if using hybrid search
# [ ] Update CORS_ORIGINS with your frontend URL
# [ ] Adjust RAG parameters based on your use case
# [ ] Test connection with: uvicorn app.main:app --reload
# ==============================================================================
