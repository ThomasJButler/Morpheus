# ==============================================================================
# MORPHEUS RAG CHATBOT - FRONTEND ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# Variables with NEXT_PUBLIC_ prefix are accessible in browser
# Variables WITHOUT prefix are server-side only (API routes)
# DO NOT commit .env.local to version control

# ==============================================================================
# SERVER-SIDE API CONFIGURATION (Required for Chat)
# ==============================================================================

# Anthropic API Key - Used by Next.js API route to call Claude
# Get from: https://console.anthropic.com/
# IMPORTANT: NO NEXT_PUBLIC prefix - this is server-side only!
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Backend URL - FastAPI backend for RAG context retrieval
# Used by Next.js API route (server-side) to fetch context
# Development: http://localhost:8000
# Production: https://your-backend.railway.app
BACKEND_URL=http://localhost:8000

# ==============================================================================
# CLIENT-SIDE BACKEND CONFIGURATION (Required)
# ==============================================================================

# Backend API URL - For document upload and other client-side calls
# This is the same URL but accessible in browser for document uploads
# Development: http://localhost:8000
# Production: https://your-backend.railway.app or https://your-backend.onrender.com
# IMPORTANT: No trailing slash
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==============================================================================
# MATRIX THEME CONFIGURATION (Optional)
# ==============================================================================

# Enable Matrix Rain Background
# true = Show animated Matrix rain (slight performance impact)
# false = Disable animation (better performance on slower devices)
NEXT_PUBLIC_ENABLE_MATRIX_RAIN=true

# Matrix Rain Intensity - How many "raindrops" to show
# Range: 0.1 (subtle) to 1.0 (intense)
# Recommendation: 0.3 for balance between aesthetics and performance
NEXT_PUBLIC_MATRIX_RAIN_INTENSITY=0.3

# Matrix Rain Speed - How fast the characters fall
# Range: 0.5 (slow) to 2.0 (fast)
# Recommendation: 1.0 for authentic Matrix feel
NEXT_PUBLIC_MATRIX_RAIN_SPEED=1.0

# Matrix Rain Color - Primary color for the rain effect
# Options: green (classic), cyan (modern), custom hex code
# Default: green (#00ff00)
NEXT_PUBLIC_MATRIX_RAIN_COLOR=green

# ==============================================================================
# STREAMING CONFIGURATION (Optional)
# ==============================================================================

# Stream Timeout - Maximum time to wait for stream response (milliseconds)
# Prevents hanging connections if backend is slow or unresponsive
# Recommendation: 30000 (30 seconds)
NEXT_PUBLIC_STREAM_TIMEOUT=30000

# Stream Retry Attempts - How many times to retry failed streams
# Helps with intermittent connection issues
# Recommendation: 3
NEXT_PUBLIC_STREAM_RETRY_ATTEMPTS=3

# Stream Retry Delay - Milliseconds to wait between retry attempts
# Exponential backoff will be applied
# Recommendation: 1000 (1 second)
NEXT_PUBLIC_STREAM_RETRY_DELAY=1000

# ==============================================================================
# FEATURE FLAGS (Optional)
# ==============================================================================

# Enable Metrics Dashboard
# Shows performance comparisons between RAG modes
# true = Display metrics in UI
# false = Hide metrics (cleaner interface)
NEXT_PUBLIC_ENABLE_METRICS=true

# Enable Document Upload
# Allows users to upload and process documents
# true = Show upload button and functionality
# false = Chat-only mode
NEXT_PUBLIC_ENABLE_DOCUMENT_UPLOAD=true

# Enable Cascading/Hybrid Mode
# Allows users to select hybrid search mode
# true = Show all 3 modes (simple, hybrid, agentic)
# false = Show only simple and agentic modes
NEXT_PUBLIC_ENABLE_CASCADING_MODE=true

# Enable Context Viewer
# Shows retrieved documents and sources in sidebar
# true = Display context panel
# false = Hide context panel (cleaner UI)
NEXT_PUBLIC_ENABLE_CONTEXT_VIEWER=true

# Enable Blue/Red Pill Mode
# Show Morpheus personality selector (Matrix theme)
# true = Show pill selector (blue = factual, red = creative)
# false = Use default personality
NEXT_PUBLIC_ENABLE_PILL_MODE=true

# ==============================================================================
# ANALYTICS & MONITORING (Optional)
# ==============================================================================

# Google Analytics Tracking ID
# Get from: https://analytics.google.com/
# Leave empty to disable analytics
NEXT_PUBLIC_GA_TRACKING_ID=

# Sentry DSN - Error tracking
# Get from: https://sentry.io/
# Leave empty to disable error reporting
NEXT_PUBLIC_SENTRY_DSN=

# Enable Performance Monitoring
# Tracks page load times, interaction times, etc.
# true = Send performance data to monitoring service
# false = Disable performance tracking
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false

# ==============================================================================
# DEVELOPMENT & DEBUG (Optional)
# ==============================================================================

# Debug Mode - Enable verbose console logging
# true = Show detailed logs in browser console (development)
# false = Minimal logging (production)
NEXT_PUBLIC_DEBUG=false

# Mock API Mode - Use mock data instead of real API calls
# Useful for frontend development without backend
# true = Use mock responses
# false = Use real backend API
NEXT_PUBLIC_MOCK_API=false

# Show Developer Tools
# Display developer panel with debugging info
# true = Show dev tools in UI (development)
# false = Hide dev tools (production)
NEXT_PUBLIC_SHOW_DEV_TOOLS=false

# ==============================================================================
# PERFORMANCE OPTIMIZATION (Optional)
# ==============================================================================

# Enable Service Worker
# Caches assets for offline support and faster loads
# true = Enable PWA capabilities
# false = Standard web app
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false

# Image Optimization
# Use Next.js Image component optimizations
# true = Optimize images (recommended)
# false = Use standard img tags
NEXT_PUBLIC_OPTIMIZE_IMAGES=true

# Prefetch Links
# Preload pages on link hover
# true = Faster navigation (uses more bandwidth)
# false = Load on click (saves bandwidth)
NEXT_PUBLIC_PREFETCH_LINKS=true

# ==============================================================================
# ACCESSIBILITY (Optional)
# ==============================================================================

# Reduce Motion - Respect prefers-reduced-motion
# true = Disable animations for users with motion sensitivity
# false = Show all animations
NEXT_PUBLIC_RESPECT_REDUCED_MOTION=true

# High Contrast Mode
# Increase color contrast for better visibility
# auto = Use system preference
# true = Force high contrast
# false = Normal contrast
NEXT_PUBLIC_HIGH_CONTRAST=auto

# ==============================================================================
# DEPLOYMENT CONFIGURATION (Platform-Specific)
# ==============================================================================

# Vercel Analytics
# Automatically enabled on Vercel deployment
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=<auto-populated>

# ==============================================================================
# SETUP CHECKLIST
# ==============================================================================
# [ ] Copy this file to .env.local
# [ ] Update NEXT_PUBLIC_API_URL with your backend URL
# [ ] Adjust Matrix theme settings to your preference
# [ ] Configure feature flags based on desired functionality
# [ ] Set up analytics/monitoring (optional)
# [ ] Test locally with: npm run dev
# [ ] Test build with: npm run build && npm start
# ==============================================================================

# ==============================================================================
# DEPLOYMENT NOTES
# ==============================================================================
# VERCEL:
#   - Environment variables auto-loaded from Vercel dashboard
#   - Set NEXT_PUBLIC_API_URL to your Railway/Render backend URL
#   - Enable Vercel Analytics in project settings
#
# NETLIFY:
#   - Add environment variables in Site settings > Environment variables
#   - Use _headers file for CORS configuration
#
# SELF-HOSTED:
#   - Ensure .env.local exists with production values
#   - Run: npm run build && npm start
#   - Consider using PM2 for process management
# ==============================================================================
