{
  "mcpServers": {
    "redis": {
      "command": "node",
      "args": [
        "/Users/tombutler/.nvm/versions/node/v22.17.0/lib/node_modules/@liangshanli/mcp-server-redis/bin/cli.js",
        "--host", "localhost",
        "--port", "6379"
      ],
      "env": {
        "REDIS_PASSWORD": "${REDIS_PASSWORD}"
      }
    },
    "sqlite": {
      "command": "node",
      "args": [
        "/Users/tombutler/.nvm/versions/node/v22.17.0/lib/node_modules/mcp-sqlite/mcp-sqlite-server.js",
        "--db-path", "/Users/tombutler/Repos/RAG-Chatbot/morpheus.db"
      ]
    },
    "docker": {
      "command": "node",
      "args": [
        "/Users/tombutler/.nvm/versions/node/v22.17.0/lib/node_modules/mcp-docker/build/index.js"
      ]
    },
    "containerization": {
      "command": "node",
      "args": [
        "/Users/tombutler/.nvm/versions/node/v22.17.0/lib/node_modules/containerization-assist-mcp/dist/src/cli/cli.js",
        "--project-path", "/Users/tombutler/Repos/RAG-Chatbot"
      ]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://user:password@localhost:5432/morpheus"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "${POSTGRES_CONNECTION_STRING}"
      }
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "browser-tools": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-browser-tools"]
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
}